---
import Layout from "../layouts/Layout.astro";
---

<Layout title="TaskFlow - Dashboard">
  <div class="container" id="app">
    <h1>Dashboard</h1>

    <div id="stats"></div>

    <h2>Tareas por categoría</h2>
    <ul id="categoriasList"></ul>

    <br />
    <a href="/tasks">Volver a tareas</a>
  </div>

  <script>
    interface Task {
      id: number;
      titulo: string;
      categoria: string;
      completada: boolean;
      fechaCreacion: string;
    }

    function updateDashboard(): void {
      const tasks: Task[] = JSON.parse(localStorage.getItem("tasks") || "[]");
      
      const total = tasks.length;
      const completadas = tasks.filter(task => task.completada).length;
      const pendientes = total - completadas;
      const porcentaje = total > 0 ? Math.round((completadas / total) * 100) : 0;

      // Estadísticas
      const statsDiv = document.getElementById('stats') as HTMLDivElement | null;
      if (statsDiv) {
        statsDiv.innerHTML = `
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1rem 0;">
            <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; text-align: center;">
              <h3>Total</h3>
              <p style="font-size: 2rem;">${total}</p>
            </div>
            <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; text-align: center;">
              <h3>Completadas</h3>
              <p style="font-size: 2rem; color: #28a745;">${completadas}</p>
            </div>
            <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; text-align: center;">
              <h3>Pendientes</h3>
              <p style="font-size: 2rem; color: #dc3545;">${pendientes}</p>
            </div>
          </div>
          <div style="background: #f8f9fa; padding: 1rem; border-radius: 8px; margin: 1rem 0;">
            <h3>Progreso: ${porcentaje}%</h3>
            <progress value="${porcentaje}" max="100" style="width: 100%; height: 20px; border-radius: 10px;"></progress>
          </div>
        `;
      }

      // Categorías
      const categorias: Record<string, number> = { Personal: 0, Trabajo: 0, Estudio: 0 };
      tasks.forEach(task => {
        if (categorias[task.categoria] !== undefined) {
          categorias[task.categoria]++;
        }
      });

      const categoriasList = document.getElementById('categoriasList') as HTMLUListElement | null;
      if (categoriasList) {
        categoriasList.innerHTML = Object.entries(categorias).map(([nombre, count]) => `
          <li style="display: flex; justify-content: space-between; padding: 0.5rem; background: #f8f9fa; border-radius: 4px; margin: 0.25rem 0;">
            <span>${nombre}</span>
            <span style="font-weight: bold;">${count}</span>
          </li>
        `).join('');
      }
    }

    // Verificar autenticación
    function checkAuth(): void {
      const isAuthenticated = localStorage.getItem("isAuthenticated");
      if (!isAuthenticated) {
        window.location.href = "/login";
      }
    }

    // Inicializar
    checkAuth();
    updateDashboard();

    // Actualizar cada vez que se cambia el localStorage
    window.addEventListener('storage', (e: StorageEvent) => {
      if (e.key === 'tasks') {
        updateDashboard();
      }
    });
  </script>
</Layout>